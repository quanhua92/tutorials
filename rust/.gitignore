# Rust build artifacts (target/ is the build cache — never commit)
target/

# Per-bundle compiled binaries never land in source dirs (runs go through
# `cargo run --bin NAME` / `just run NAME`), but guard anyway:
core/ownership
core/borrowing
core/lifetimes

# Coverage / profiling
*.profraw
tarpaulin-report.html
cobertura.xml

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Local env / secrets (NEVER commit)
.env
.env.*
*.local
