# ── Node / pnpm dependencies ────────────────────────────────────────────────
# No leading slash so this ALSO catches nested workspace node_modules
# (core/, web/, hono/, ...) — the repo-root .gitignore only covers /node_modules.
node_modules/

# ── Build output ────────────────────────────────────────────────────────────
# Bundles run via `tsx` (esbuild, in-memory) and leave NOTHING. This guards
# against accidental `tsc` / `tsup` / `esbuild` invocations dropping artifacts.
dist/
build/
out/
*.tsbuildinfo

# ── Coverage / profiling (Vitest, c8/istanbul, node --prof) ─────────────────
coverage/
*.prof
*.cpuprofile
*.heapprofile

# ── pnpm ────────────────────────────────────────────────────────────────────
.pnpm-debug.log*
.pnpm-store/

# ── Tool caches ─────────────────────────────────────────────────────────────
.cache/
.eslintcache

# ── Editor / OS ─────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# ── Local env / secrets (NEVER commit) ──────────────────────────────────────
.env
.env.*
*.local

# ════════════════════════════════════════════════════════════════════════════
# DO NOT IGNORE (these ARE committed — they are the bundle, not artifacts):
#   *_output.txt      captured stdout (== go/*.txt, rust/*_output.txt) — ground truth
#   pnpm-lock.yaml    deterministic installs (== Cargo.lock / go.sum)
#   tsconfig*.json    the build contract
# ════════════════════════════════════════════════════════════════════════════
