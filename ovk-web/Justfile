# ovk-web — concept-builder curriculum (RFC 0001 → Google Vids frontend clone)
# Usage: `just <recipe>`. Install just: brew install just

# Run one bundle's ground-truth runnable to stdout.
run name:
    pnpm exec tsx bundles/{{name}}.ts

# Capture a bundle's stdout to <name>_output.txt (committed ground truth).
out name:
    pnpm exec tsx bundles/{{name}}.ts > bundles/{{name}}_output.txt 2>/dev/null

# Typecheck the whole project (tsc --noEmit).
check:
    pnpm run check

# Lint.
lint:
    pnpm run lint

# Format check (ts/runnables are hand-stable; placeholder for future prettier).
fmt:
    @echo "fmt: no formatter wired (runnables are hand-stable)"

# Validate every mermaid block in all .md guides renders (SKILL §15.1).
mermaid:
    node scripts/mermaid_check.mjs .

# Run the HTML runtime smoke test on every bundle .html (SKILL §15.2).
htmlcheck:
    node scripts/html_runtime_check.js bundles

# Full verification sweep over every bundle.
sweep:
    bash scripts/sweep.sh

# Scaffold a new bundle from the skeleton.
new name:
    cp scripts/skeleton.ts bundles/{{name}}.ts
    @echo "created bundles/{{name}}.ts — fill it in, then: just out {{name}}"

# Serve the dashboard.
dev:
    pnpm dev
